# Gemi env vars — copy to .env (or set in your shell) and fill in.
# Only needed if you enable the corresponding paid-API MCP servers.
# All FREE-tier features work without any of these.

# GitHub MCP (only if "github" is enabled in mcp.json)
GITHUB_TOKEN=

# Supabase MCP (only if "supabase" is enabled)
SUPABASE_ACCESS_TOKEN=

# Notion MCP (only if "notion" is enabled)
NOTION_TOKEN=

# Brave Search MCP (free tier available)
BRAVE_API_KEY=

# Cloudflare MCP
CLOUDFLARE_API_TOKEN=

# HuggingFace
HF_TOKEN=
